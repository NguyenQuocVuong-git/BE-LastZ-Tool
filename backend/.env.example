# Cổng HTTP
PORT=3000

# URL công khai của server (HTTPS), dùng cho Telegram setWebhook — không có dấu / cuối
# Vercel: https://<ten-project>.vercel.app (hoặc domain tùy chỉnh)
SERVER_URL=https://yourdomain.com

NODE_ENV=development

# PostgreSQL (development: NODE_ENV != production)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tool_backend
DB_USER=postgres
DB_PASSWORD=your_password

# Production (NODE_ENV=production): Neon / hosted Postgres
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Chuỗi bí mật chung (có thể dùng cho tương lai; hiện session dùng token ngẫu nhiên trong DB)
SESSION_SECRET=thay_bang_chuoi_32_ky_tu_ngau_nhien

# Telegram Bot (webhook)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# Chat ID của admin duy nhất được bấm nút (số nguyên, ví dụ: 123456789)
TELEGRAM_CHAT_ID=123456789
# Chuỗi bí mật trong path webhook: /webhook/telegram/<TELEGRAM_WEBHOOK_SECRET>
TELEGRAM_WEBHOOK_SECRET=thay_bang_chuoi_random_khac

# Thông tin chuyển khoản / VietQR (số tài khoản không dấu cách)
BANK_ACCOUNT_NUMBER=0123456789
BANK_ACCOUNT_NAME=NGUYEN VAN A
# Mã ngân hàng theo VietQR (BIN), ví dụ MB: 970422
BANK_BIN=970422

# SePay webhook
SEPAY_API_KEY=your_sepay_api_key_here
IS_PRODUCTION=false

# Gửi email (quên mật khẩu): SMTP — ví dụ Gmail App Password dùng port 587, secure=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
# true nếu TLS ngay từ đầu (thường port 465)
SMTP_SECURE=false
SMTP_USER=quocvuong1121212nguyen1235@gmail.com
SMTP_PASS=yygx qwzzlvx znqzxczz23212s sadas
SMTP_FROM="noreply@example.com"
# Tuỳ chọn
# SMTP_PASSWORD_RESET_SUBJECT=Mật khẩu đăng nhập mới
# APP_NAME=Tool LastZ
