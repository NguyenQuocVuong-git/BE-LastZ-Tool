# Cổng HTTP
PORT=3000

# URL công khai của server (HTTPS), dùng cho Telegram setWebhook — không có dấu / cuối
SERVER_URL=https://yourdomain.com

NODE_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tool_backend
DB_USER=postgres
DB_PASSWORD=your_password

# Chuỗi bí mật chung (có thể dùng cho tương lai; hiện session dùng token ngẫu nhiên trong DB)
SESSION_SECRET=thay_bang_chuoi_32_ky_tu_ngau_nhien

# Telegram Bot (webhook)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# Chat ID của admin duy nhất được bấm nút (số nguyên, ví dụ: 123456789)
TELEGRAM_CHAT_ID=123456789
# Chuỗi bí mật trong path webhook: /webhook/telegram/<TELEGRAM_WEBHOOK_SECRET>
TELEGRAM_WEBHOOK_SECRET=thay_bang_chuoi_random_khac

# Thông tin chuyển khoản / VietQR (số tài khoản không dấu cách)
BANK_ACCOUNT_NUMBER=0123456789
BANK_ACCOUNT_NAME=NGUYEN VAN A
# Mã ngân hàng theo VietQR (BIN), ví dụ MB: 970422
BANK_BIN=970422
