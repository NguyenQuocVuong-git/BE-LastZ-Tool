# Cổng HTTP
PORT=3000

# URL công khai của server (HTTPS), dùng cho Telegram setWebhook — không có dấu / cuối
# Vercel: https://<ten-project>.vercel.app (hoặc domain tùy chỉnh)
SERVER_URL=https://yourdomain.com

# URL frontend (link reset mật khẩu / xác minh email) — không có dấu / cuối
APP_PUBLIC_URL=https://yourdomain.com

NODE_ENV=development

# PostgreSQL (development: NODE_ENV != production)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tool_backend
DB_USER=postgres
DB_PASSWORD=your_password

# Production (NODE_ENV=production): Neon / hosted Postgres
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
# Bật xác thực chứng chỉ SSL đầy đủ (khuyến nghị production):
# DB_SSL_REJECT_UNAUTHORIZED=true

# Bắt buộc production — dùng HMAC session / token reset (≥ 32 ký tự ngẫu nhiên)
SESSION_SECRET=thay_bang_chuoi_32_ky_tu_ngau_nhien

# CORS: danh sách origin FE, phân tách bằng dấu phẩy (bắt buộc khi IS_PRODUCTION=true)
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Telegram Bot (webhook)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID=123456789
TELEGRAM_WEBHOOK_SECRET=thay_bang_chuoi_random_khac

# Thông tin chuyển khoản / VietQR
BANK_ACCOUNT_NUMBER=0123456789
BANK_ACCOUNT_NAME=NGUYEN VAN A
BANK_BIN=970422

# SePay webhook — production: IS_PRODUCTION=true và SEPAY_API_KEY bắt buộc
SEPAY_API_KEY=your_sepay_api_key_here
IS_PRODUCTION=false
# Chỉ local dev: cho phép webhook SePay không Apikey (KHÔNG dùng production)
# ALLOW_UNVERIFIED_SEPAY_WEBHOOK=true

# Rate limit đồng bộ DB (mặc định bật khi NODE_ENV=production hoặc IS_PRODUCTION=true)
# USE_PG_RATE_LIMIT=true

# Gửi email
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user@example.com
SMTP_PASS=your-smtp-app-password
SMTP_FROM="noreply@example.com"
# SMTP_PASSWORD_RESET_SUBJECT=Đặt lại mật khẩu
# SMTP_VERIFY_SUBJECT=Xác minh email đăng ký
# APP_NAME=Tool LastZ

# DOWNLOAD_DIR=./download
